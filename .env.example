# Copia este archivo como .env y rellena los valores.
# El .env real NO se sube a git (esta en .gitignore).

# ---- General ----
NODE_ENV=development

# ---- MySQL 8 ----
DB_ROOT_PASSWORD=
DB_NAME=reservas_db
DB_USER=reservas_user
DB_PASSWORD=
DB_PORT=3306

# ---- Backend (Node + Express) ----
BACKEND_PORT=4000
JWT_SECRET=
CORS_ORIGIN=http://localhost:5173

# ---- Frontend (React + Vite) ----
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:4000/api
